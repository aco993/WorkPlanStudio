# Normalise line endings on commit; let git detect what is text.
* text=auto eol=lf

# Scripts keep their platform-native endings
*.sh   text eol=lf
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — no eol normalisation, no text diffing
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff  binary
*.woff2 binary

# GitHub linguist — keep the language stats focused on the app's own code,
# not the vendored Bootstrap bundle or the docs.
src/WorkPlanStudio/wwwroot/lib/** linguist-vendored
docs/**                           linguist-documentation
*.md                              linguist-documentation
